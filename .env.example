# ============================================
# LLM-Plug 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ============================================

# --------------------------------------------
# 服务器配置
# --------------------------------------------
# 服务监听地址，0.0.0.0 表示监听所有接口
HOST=0.0.0.0

# 服务监听端口，与 docker-compose 映射需保持一致
PORT=55555

# --------------------------------------------
# 数据存储（除统计外的本地数据）
# --------------------------------------------
# 本地数据文件存放目录，默认在项目根目录下
# DATA_DIR=./data

# 渠道配置文件路径（负载均衡上游定义）
# CHANNELS_FILE=./data/channels.json

# API 密钥文件路径（渠道调用密钥）
# API_KEYS_FILE=./data/api_keys.json

# --------------------------------------------
# PostgreSQL 统计数据库
# --------------------------------------------
# 生产/运行时数据库连接 URL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://user:password@localhost:5432/llmplug

# 测试数据库连接 URL（仅测试及调试脚本使用）
# TEST_DATABASE_URL=postgresql://user:password@localhost:5432/llmplug_test

# 统计模块追踪的请求头（逗号分隔）
# 匹配到的请求头会存入 requests.headers JSONB 字段，用于后续按 App 统计
# 留空或设为 ALL 表示追踪所有请求头，不设置此变量则默认追踪所有
# STATS_TRACKED_HEADERS=X-App-Name,X-Request-ID,User-Agent

# --------------------------------------------
# 代理鉴权
# --------------------------------------------
# 全局代理访问密钥，设置后所有请求需携带 Authorization: Bearer <密钥>
# 留空表示不启用鉴权
PROXY_API_KEY=

# --------------------------------------------
# 负载均衡与超时
# --------------------------------------------
# 渠道连续失败多少次后暂时从负载均衡池中剔除
MAX_FAIL_COUNT=5

# 渠道被剔除后的冷却恢复时间（秒）
COOLDOWN_SECONDS=60

# 单次代理请求超时时间（秒）
REQUEST_TIMEOUT=300

# --------------------------------------------
# Debug 与日志
# --------------------------------------------
# 是否开启 Debug 模式（true/false）
# Debug 开启后：start.sh 会进入 reload 模式、打印 trace 级别日志、输出彩色日志
DEBUG=false

# 日志级别: debug, info, warning, error
# 影响 uvicorn 及程序内日志输出
LOG_LEVEL=info

# Debug 详细日志保存目录（需 DEBUG=true 才生效）
# DEBUG_LOG_DIR=./logs
