# ============================================================
#  LLM-Plug 环境变量配置
# ============================================================
#
# 所有变量均有合理默认值，不设置即可正常运行。
# 复制本文件为 .env 后按需取消注释并修改。
#
# 使用方式：
#   docker compose --env-file .env up -d
#   或在 docker-compose.yml 的 environment / .env_file 中引用。
#
# 生效文件速查：
#   docker-deploy/Dockerfile   — 容器构建，uvicorn 启动参数
#   docker-deploy/docker-compose.yml — 容器运行时环境变量
#   start.sh                   — 裸机部署启动脚本
#   stats.py                   — 统计聚合库（SQLite PRAGMA + 内部 worker）
#   request_logs.py            — 请求日志库（SQLite PRAGMA + 内部 worker）

# ------------------------------------------------------------
#  uvicorn 启动参数（需重启容器生效）
# ------------------------------------------------------------
# 生效文件：docker-deploy/Dockerfile (CMD)
#           start.sh (uvicorn 命令行)

# 工作进程数
# 每个 worker 是一个独立进程，共享同一端口。
# 单进程已足够处理大部分 LLM 代理负载（瓶颈通常在上游 API 延迟）。
# 仅在高并发场景下考虑调大，建议值 = CPU 核数。
# 默认值：1
#WORKERS=1

# 日志级别
# 可选值：debug / info / warning / error
# debug 模式会输出每个 SSE chunk 的内容，仅排障时使用。
# 默认值：info
#LOG_LEVEL=info

# HTTP keep-alive 超时（秒）
# 客户端连接在无数据传输后保持打开的最长时间。
# 流式响应通常耗时较长，建议不低于 300。
# 默认值：360
#TIMEOUT_KEEP_ALIVE=360

# ------------------------------------------------------------
#  内部异步 worker 协程数（需重启容器生效）
# ------------------------------------------------------------
# 生效文件：stats.py (_STATS_WORKER_COUNT)
#           request_logs.py (_REQUEST_WORKER_COUNT)
#
# 这些协程在单个 uvicorn 进程内运行，负责消费内部队列并写入 SQLite。
# 与 uvicorn workers 无关——它们是 asyncio 协程，不是操作系统进程。
# 仅在高并发导致队列堆积时考虑调大。

# 统计写入协程数
# 负责将请求统计数据异步写入 stats.db。
# 生效位置：stats.py:62
# 默认值：4
#STATS_WORKER_COUNT=4

# 请求日志写入协程数
# 负责将完整请求/响应记录异步写入 request_logs.db（按月分库）。
# 生效位置：request_logs.py:78
# 默认值：2
#REQUEST_LOG_WORKER_COUNT=2

# ------------------------------------------------------------
#  SQLite PRAGMA 调优（需重启容器生效）
# ------------------------------------------------------------
# 生效文件：stats.py (统计聚合库)
#           request_logs.py (请求日志库)
#
# 项目使用两个独立的 SQLite 数据库：
#   - request_logs.db  — 请求日志（按月分库，数据量大，写入密集）
#   - stats.db         — 统计聚合（日粒度汇总，数据量小）
# 两个库可以分别配置 mmap_size，其余 PRAGMA 共享同一份配置。

# cache_size：每连接的页缓存大小
# 负值表示 KiB（例如 -16000 = 16MB）。
# 正值表示页数（页大小通常 4KB）。
# 增大可减少磁盘 I/O，但会占用更多内存。
# 生效位置：request_logs.py:196, stats.py:137
# 默认值：-16000（16MB）
#SQLITE_CACHE_SIZE=-16000

# temp_store：临时表/索引的存储位置
# MEMORY — 临时数据存内存，减少磁盘 I/O，但占用更多内存
# FILE   — 临时数据落盘，内存占用低
# DEFAULT — 由 SQLite 编译时决定
# 生效位置：request_logs.py:195, stats.py:136
# 默认值：FILE
#SQLITE_TEMP_STORE=FILE

# journal_mode：日志模式（WAL 推荐）
# WAL        — Write-Ahead Logging，并发读写性能最佳，推荐
# DELETE     — 传统模式，每次事务写回原文件
# TRUNCATE / PERSIST / MEMORY — 不同的回滚日志处理策略
# OFF        — 禁用日志（危险，断电可能损坏数据库）
# 生效位置：request_logs.py:208, stats.py:185
# 默认值：WAL
#SQLITE_JOURNAL_MODE=WAL

# synchronous：同步写盘策略
# NORMAL — WAL 模式下的推荐值，平衡安全与性能
# FULL   — 每次事务都 fsync，最安全但最慢
# OFF    — 完全不同步，最快但断电可能丢数据
# 生效位置：request_logs.py:194, stats.py:135
# 默认值：NORMAL
#SQLITE_SYNCHRONOUS=NORMAL

# mmap_size：内存映射 I/O 大小（字节）
# 启用 mmap 后，SQLite 直接将数据库文件映射到虚拟内存，
# 由 OS 管理页面换入换出，随机读性能显著提升。
# 两个数据库分别配置，因为数据量和访问模式不同：

# 请求日志库 mmap 大小（默认 64MB）
# 请求日志按月分库，单库可达数百 MB，较大的 mmap 有助于随机查询。
# 生效位置：request_logs.py:199
#SQLITE_MMAP_SIZE_LOGS=67108864

# 统计聚合库 mmap 大小（默认 32MB）
# 统计库数据量小，32MB 足够覆盖热数据。
# 生效位置：stats.py:140
#SQLITE_MMAP_SIZE_STATS=33554432

# ------------------------------------------------------------
#  容器环境
# ------------------------------------------------------------

# 时区
# 影响日志时间戳显示和 cron 定时任务。
# 生效位置：OS 级（tzdata），Python 代码不直接读取
# 默认值：Asia/Shanghai
#TZ=Asia/Shanghai
