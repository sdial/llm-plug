# ============================================
# LLM-Plug 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ============================================

# --------------------------------------------
# 服务器配置
# --------------------------------------------
HOST=0.0.0.0
PORT=55555

# --------------------------------------------
# 数据存储（除统计外的本地数据）
# --------------------------------------------
# DATA_DIR=./data
# CHANNELS_FILE=./data/channels.json
# API_KEYS_FILE=./data/api_keys.json

# --------------------------------------------
# 负载均衡与超时
# --------------------------------------------
# 渠道连续失败多少次后暂时剔除
MAX_FAIL_COUNT=5

# 剔除后的冷却恢复时间（秒）
COOLDOWN_SECONDS=120

# 单次代理请求超时时间（秒）
REQUEST_TIMEOUT=300

# --------------------------------------------
# 日志
# --------------------------------------------
# 日志级别: debug, info, warning, error
LOG_LEVEL=info
